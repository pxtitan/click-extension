{
  "manifest_version": 3,
  "name": "Click Extension",
  "version": "1.0.0",
  "description": "Search selected text in a new tab by pressing CTRL + ENTER.",
  "author": "pxtitan",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
